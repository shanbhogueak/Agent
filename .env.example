OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4
PORT=8080

# Optional: verify webhook signatures.
OPENAI_WEBHOOK_SECRET=whsec_...

# JSON array of MCP server configs.
# Example:
# [{"label":"crm","url":"https://mcp.example.com/sse","description":"CRM tools","requireApproval":"always"}]
MCP_SERVERS_JSON=[]

# Optional path to an MCP config file in the same shape used by Codex/Claude Desktop.
# URL-based entries are attached automatically; command-based entries are reported as skipped.
MCP_CONFIG_PATH=./mcp.config.json

# Optional JSON array of hosted skill references.
# Example:
# [{"skill_id":"openai-spreadsheets","version":"latest"}]
SKILL_REFS_JSON=[]

# Optional: include built-in web search tool.
ENABLE_WEB_SEARCH=false

# Comma-separated candidate paths for persistent role context.
# First existing file is loaded on each request.
AGENT_CONTEXT_PATHS=./agents.md,./AGENTS.md,./claude.md,./CLAUDE.md

# Persistent memory file (manual long-term preferences).
MEMORY_FILE_PATH=./memory.md

# Runtime memory backend: none | file | redis | postgres
MEMORY_BACKEND=file

# Used when MEMORY_BACKEND=file
MEMORY_STORE_FILE_PATH=./memory.store.jsonl

# Number of runtime memory entries injected per request.
MEMORY_MAX_CONTEXT_ENTRIES=20

# Used when MEMORY_BACKEND=redis
REDIS_URL=redis://localhost:6379

# Used when MEMORY_BACKEND=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/agent
